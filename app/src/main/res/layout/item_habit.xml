<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="habit"
            type="com.example.habittracker_semogaberuntung.Habit" />

        <variable
            name="listener"
            type="com.example.habittracker_semogaberuntung.HabitAdapter.OnHabitActionListener" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHabit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="6dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:strokeWidth="2dp"
        app:strokeColor="@{habit.progress >= habit.goal ? @android:color/holo_green_dark : @android:color/darker_gray}">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Icon dengan badge lingkaran, biar gak keliatan kotak polos -->
            <FrameLayout
                android:id="@+id/iconContainer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_circle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:contentDescription="Habit Icon"
                    android:scaleType="centerInside"
                    android:src="@{habit.icon}" />
            </FrameLayout>

            <!-- Habit Name (tekan -> pindah ke Edit Habit) -->
            <TextView
                android:id="@+id/tvHabitName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:text="@{habit.name}"
                android:onClick="@{() -> listener.onTitleClick(habit)}"
                app:layout_constraintStart_toEndOf="@id/iconContainer"
                app:layout_constraintEnd_toStartOf="@id/tvStatus"
                app:layout_constraintTop_toTopOf="@id/iconContainer" />

            <!-- Status Label -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{habit.progress >= habit.goal ? `Completed` : `In Progress`}"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@{habit.progress >= habit.goal ? @android:color/holo_green_dark : @android:color/darker_gray}"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/iconContainer" />

            <!-- Description -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="?android:textColorSecondary"
                android:layout_marginStart="16dp"
                android:layout_marginTop="2dp"
                android:text="@{habit.description}"
                app:layout_constraintStart_toEndOf="@id/iconContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvHabitName" />

            <!-- Progress Text -->
            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{`Progress : ` + habit.progress + ` / ` + habit.goal + ` ` + habit.unit}"
                android:textSize="14sp"
                android:layout_marginTop="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iconContainer" />

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_marginTop="6dp"
                android:max="@{habit.goal}"
                android:progress="@{habit.progress}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvProgress" />

            <!-- Minus Button (listener binding) -->
            <Button
                android:id="@+id/btnMinus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="-"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/design_default_color_error"
                android:onClick="@{() -> listener.onDecrement(habit)}"
                android:enabled="@{habit.progress &lt; habit.goal}"
                android:alpha="@{habit.progress >= habit.goal ? 0.5f : 1f}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progressBar"
                android:layout_marginTop="14dp" />

            <!-- Plus Button (listener binding) -->
            <Button
                android:id="@+id/btnPlus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="+"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/design_default_color_primary"
                android:onClick="@{() -> listener.onIncrement(habit)}"
                android:enabled="@{habit.progress &lt; habit.goal}"
                android:alpha="@{habit.progress >= habit.goal ? 0.5f : 1f}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progressBar"
                android:layout_marginTop="14dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>